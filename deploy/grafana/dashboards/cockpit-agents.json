{
  "id": null,
  "uid": "cockpit-agents",
  "title": "Cockpit Agents — 时延 / 成功率 / 熔断",
  "description": "T3.6: Agent 时延、成功率、熔断状态曲线（数据源 observability-collector /metrics）",
  "tags": ["cockpit", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Agent 平均延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cockpit-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cockpit-prometheus" },
          "expr": "cockpit_agent_latency_seconds_avg{agent_id=~\".+\"}",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Agent 成功率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cockpit-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cockpit-prometheus" },
          "expr": "(1 - cockpit_agent_error_rate{agent_id=~\".+\"}) * 100",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "title": "Agent 熔断状态",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "cockpit-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cockpit-prometheus" },
          "expr": "cockpit_agent_circuit_state{agent_id=~\".+\"}",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Closed", "color": "green" },
                "1": { "text": "Half-Open", "color": "yellow" },
                "2": { "text": "Open", "color": "red" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showValue": "always",
        "mergeValues": true,
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}
