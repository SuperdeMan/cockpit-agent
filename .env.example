# 复制为 .env 并填值。切勿提交 .env。
# 注意：值后面不要加行内注释（会被解析为值的一部分）

# ── LLM ──
# 更换服务商只改这里、不动代码：anthropic 走 Claude SDK；其余一律走 OpenAI 兼容 HTTP。
# provider: xiaomimimo | anthropic | openai | deepseek | qwen | 自建（任意 OpenAI 兼容服务）
LLM_PROVIDER=xiaomimimo
LLM_API_KEY=
# OpenAI 兼容服务商的端点/鉴权/思考开关（anthropic 不用这三项）：
#   LLM_BASE_URL    chat/completions 完整 URL；留空=小米 MiMo 默认端点
#   LLM_AUTH_STYLE  api-key（默认，MiMo）| bearer（OpenAI/DeepSeek/Qwen 等多数服务）
#   LLM_DISABLE_THINKING  true（默认，MiMo 推理模型须关思考保结构化输出）| false（非推理服务商置 false）
#     注：这只是**全局默认**。复杂任务（行程/深度调研/多步聚合）由编排层经 meta["thinking"]
#     动态开思考、提质（reasoning 留后端不下发）；结构化 JSON 的 Planner 恒不开。
# 例：切 DeepSeek → LLM_PROVIDER=deepseek, LLM_BASE_URL=https://api.deepseek.com/v1/chat/completions,
#     LLM_AUTH_STYLE=bearer, LLM_DISABLE_THINKING=false, LLM_MODEL_PRIMARY=deepseek-chat
LLM_BASE_URL=
LLM_AUTH_STYLE=api-key
LLM_DISABLE_THINKING=true
# MiMo docs: https://platform.xiaomimimo.com/docs/zh-CN/quick-start/first-api-call
LLM_MODEL_PRIMARY=mimo-v2.5-pro
LLM_MODEL_FALLBACK=mimo-v2.5
# 开放域/闲聊默认走"快"模型降延迟（task 4 模型分层）；deep 偏好时才用 primary
LLM_MODEL_FAST=mimo-v2.5
PLANNER_LOOP_MAX_ITERS=2
PLANNER_LOOP_BUDGET_MS=5000

# ── 多 LLM 源（HMI 设置页两级切换：厂商→模型，全局生效，默认 = 上面的 LLM_PROVIDER）──
# 每家填了 key 即在切换入口出现（未填置灰）。切换持久化到 Redis（llm:active）：网关重启/
# 重建自动恢复上次选择，不再回落 LLM_PROVIDER 默认（Redis 不可达时才降级内存态）。
# thinking/token 参数差异由网关按厂商内置（无需你配）。
# MiniMax（LLM MiniMax-M3 + TTS 同一把 key）。docs https://platform.minimaxi.com/docs
MINIMAX_API_KEY=
MINIMAX_LLM_MODEL=MiniMax-M3
# DeepSeek（deepseek-v4-pro / deepseek-v4-flash，OpenAI 兼容）。docs https://api-docs.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_PRIMARY=deepseek-v4-pro
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
# 阿里百炼 qwen3.7（复用现有百炼 key = 下面的 LLM_EMBED_API_KEY / DASHSCOPE_ASR_KEY，无需新 key）。
# 仅当百炼 LLM 用独立计费子账号时，才填 DASHSCOPE_LLM_KEY 覆盖。
QWEN_MODEL_PRIMARY=qwen3.7-max
QWEN_MODEL_FAST=qwen3.7-plus
# DASHSCOPE_LLM_KEY=

# ── Embedding（记忆语义检索）──
# memory 经 llm-gateway 取文本向量做语义召回。默认阿里云百炼 text-embedding-v4（1024 维）。
# MiMo 不提供 embeddings，故 embedding 用独立服务商+独立 key（与上面的 LLM_API_KEY 分开）。
# **只需填 LLM_EMBED_API_KEY=<你的百炼 key>**；其余有默认值。维度须与 EMBED_DIM 一致。
# 留空 LLM_EMBED_API_KEY → 无 embedding 源 → 记忆召回诚实降级 lexical（不影响其余功能）。
LLM_EMBED_API_KEY=
LLM_EMBED_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
LLM_EMBED_MODEL=text-embedding-v4
LLM_EMBED_AUTH_STYLE=bearer
LLM_EMBED_DIMENSIONS=1024
EMBED_DIM=1024
# 百炼 docs: https://help.aliyun.com/zh/model-studio/embedding-interfaces-compatible-with-openai

# ── ASR（语音识别，批处理面 /api/asr + gRPC Transcribe）──
# 引擎：auto（默认：LLM_PROVIDER 为 MiMo 系→MiMo；否则有百炼 key→桥接 dashscope 流式引擎；
#   都没有→mock）| mimo（钉住 MiMo，chat 换家后批处理仍用 MiMo）| dashscope | mock
# 即「不用 MiMo」时批处理 ASR 不会哑成 mock，跟随 dashscope 自动可用。
ASR_PROVIDER=auto
# MiMo ASR: mimo-v2.5-asr（复用 LLM_API_KEY——多 LLM 源惯例下该 env 即 MiMo 的 key）
# MiMo ASR docs: https://platform.xiaomimimo.com/docs/zh-CN/api/audio/Speech-Recognition
ASR_MODEL=mimo-v2.5-asr
ASR_LANGUAGE=zh
# MiMo 音频端点（批/流式 ASR/TTS 共用；与 chat 的 LLM_BASE_URL 独立），留空=官方集群
MIMO_AUDIO_BASE_URL=

# ── 流式 ASR（实时识别上屏）见 docs/design/2026-06-30-asr-streaming-design.md ──
# 引擎：dashscope（DashScope 实时 qwen3，OpenAI Realtime 协议，真栈验证可用，默认）| mimo-chunked（MiMo 分块回退）| off
ASR_STREAM_PROVIDER=dashscope
# DashScope 实时 ASR（百炼）：留空则复用上面的 LLM_EMBED_API_KEY（同一把百炼 key）
DASHSCOPE_ASR_KEY=
DASHSCOPE_ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# 默认模型（真栈实测可用，注意全小写 id）：qwen3-asr-flash-realtime-2026-02-10
ASR_STREAM_MODEL=qwen3-asr-flash-realtime-2026-02-10

# ── TTS（语音合成，批处理面 /api/tts + gRPC Synthesize；HMI 流式回退/唤醒提示音走这里）──
# 引擎：auto（默认：LLM_PROVIDER 为 MiMo 系→MiMo；否则桥接 TTS_STREAM_PROVIDER 对应流式
#   引擎；都不可用→mock）| mimo | cosyvoice | qwen | minimax | mock
# 即「不用 MiMo」时批处理 TTS（含唤醒提示音）自动跟随流式引擎，不再哑成 mock。
TTS_PROVIDER=auto
# MiMo TTS: mimo-v2.5-tts（复用 LLM_API_KEY）
# MiMo TTS docs: https://platform.xiaomimimo.com/docs/zh-CN/usage-guide/speech-synthesis-v2.5
TTS_MODEL=mimo-v2.5-tts
TTS_VOICE_ID=冰糖                 # 默认音色（中文女声）；非 MiMo 引擎收到不认识的音色会自动用该引擎默认
# 可选中文音色：茉莉(女) | 苏打(男) | 白桦(男)
# 可选英文音色：Mia(女) | Chloe(女) | Milo(男) | Dean(男)
# 默认：mimo_default（中国集群默认冰糖）
TTS_FORMAT=wav                    # 输出格式：wav（非流式）| pcm16（流式）

# ── 流式 TTS（服务端 PCM 流式合成 + barge-in）见 docs/design/2026-07-04-r4.2-streaming-tts-bargein.md ──
# 引擎：cosyvoice（DashScope cosyvoice-v3-flash，run-task，469ms 首帧，默认）| qwen（qwen3-tts-flash-realtime，含方言）
#   | mimo（MiMo v2.5 流式，复用上面 LLM_API_KEY）| minimax（MiniMax T2A 流式，复用 MINIMAX_API_KEY）| mock | off
# cosyvoice/qwen 复用 DASHSCOPE_ASR_KEY / LLM_EMBED_API_KEY（同一把百炼 key）；无 key → HMI 无感回退句级批处理 /api/tts
TTS_STREAM_PROVIDER=cosyvoice
# TTS_STREAM_MODEL 留空用引擎默认（cosyvoice-v3-flash / qwen3-tts-flash-realtime）
TTS_STREAM_MODEL=
# TTS_STREAM_VOICE 留空用引擎默认（cosyvoice: longxiaochun_v3 龙小淳 / qwen: Cherry）；HMI 设置可覆盖
TTS_STREAM_VOICE=
DASHSCOPE_TTS_INFERENCE_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_TTS_REALTIME_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# MiniMax TTS（与 MiniMax LLM 同 MINIMAX_API_KEY）：模型 / 默认音色 / T2A 端点
# docs https://platform.minimaxi.com/docs/api-reference/speech-t2a-http.md
MINIMAX_TTS_MODEL=speech-2.8-turbo
MINIMAX_TTS_VOICE=female-tianmei
MINIMAX_T2A_URL=https://api.minimaxi.com/v1/t2a_v2

# ── 外部 API（选配，不配走 mock）──
# 注意：值后不要加行内注释；注释单独成行。
# 导航：高德 Web 服务。POI_VENDOR=amap 且 AMAP_KEY 非空 → 真实，否则 mock。
# docs: https://lbs.amap.com/api/webservice/guide/api/georegeo
POI_VENDOR=mock
AMAP_KEY=
# info-agent 用同一把 AMAP_KEY 将已授权定位坐标反查为可读地址；nearby-agent（周边发现）用它搜 POI 2.0 富数据（评分/人均/电话/营业时间）；不配置时仅显示“当前位置”/走 mock。
# 天气：和风 QWeather。显式设 WEATHER_VENDOR=qweather；完整 JWT 或 API Key 凭证也会自动启用真实 Provider。
# QWEATHER_HOST 填控制台的 API Host（如 xxxx.qweatherapi.com）或 devapi.qweather.com / api.qweather.com。
# 鉴权二选一（JWT 优先）：
#   (A) JWT（和风新版，推荐）：项目ID(sub) + 凭据ID(kid) + Ed25519 私钥
#       推荐 QWEATHER_PRIVATE_KEY 单行 PEM/裸 base64（换行用 \n）；文件路径用 QWEATHER_PRIVATE_KEY_PATH，容器内必须挂载该文件。
#   (B) API Key（旧版）：QWEATHER_KEY；仅可调用仍支持 API Key 的 V7 天气接口。
#       空气质量和天气预警使用 /airquality/v1/current/{latitude}/{longitude}、/weatheralert/v1/current/{latitude}/{longitude}，均必须使用上面的 JWT。
# docs: https://dev.qweather.com/docs/configuration/authentication/
WEATHER_VENDOR=mock
QWEATHER_HOST=devapi.qweather.com
QWEATHER_PROJECT_ID=
QWEATHER_KEY_ID=
QWEATHER_PRIVATE_KEY=
QWEATHER_PRIVATE_KEY_PATH=
QWEATHER_KEY=
# 联网搜索：优先 Exa（返回正文级内容，接地合成的原料前提）→ AnySearch → Bing → mock。
# Exa（AI 搜索，contents.text 直接回正文）：docs https://exa.ai/docs/reference/search
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
# AnySearch（兜底搜索 + extract 抓正文）：docs https://anysearch.com/docs
ANYSEARCH_API_KEY=
ANYSEARCH_BASE_URL=https://api.anysearch.com
# Bing Web Search（再降级）：docs https://learn.microsoft.com/en-us/bing/search-apis/bing-web-search/
BING_SEARCH_KEY=
# 新闻：SerpApi（Google News + Baidu News，AnySearch 兜底）→ mock。
# docs: https://serpapi.com/google-news-api | https://serpapi.com/baidu-news-api
SERPAPI_API_KEY=
# 赛事：api-football（实时比分/赛程，世界杯 league=1）。docs https://www.api-football.com/documentation-v3
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
# 旧 NewsAPI（向后兼容，有 SERPAPI_API_KEY 时优先 SerpApi）
NEWS_API_KEY=
# 股票：Tushare（免费 API）→ mock。docs: https://tushare.pro/document/1?doc_id=5
TUSHARE_TOKEN=
# 旧 Alpha Vantage（向后兼容，有 TUSHARE_TOKEN 时优先 Tushare）
STOCK_API_KEY=
# 其他厂商（PoC 未接，预留）
# BAIDU_MAP_KEY=
# DIANPING_KEY=
# ETCP_KEY=
# PGVECTOR_DSN=

# ── 基础设施 ──
REDIS_URL=redis://redis:6379/0
NATS_URL=nats://nats:4222
POSTGRES_DSN=postgresql://cockpit:cockpit@postgres:5432/cockpit

# ── 服务地址（容器内 DNS）──
REGISTRY_ADDR=registry:50051
LLM_GATEWAY_ADDR=llm-gateway:50052
MEMORY_ADDR=memory:50053
CLOUD_PLANNER_ADDR=cloud-planner:50054
CLOUD_GATEWAY_ADDR=cloud-gateway:8080

# ── 部署注意 ──
# 浏览器 getUserMedia 要求安全上下文（HTTPS 或 localhost）。
# 车机 webview / 局域网演示环境需配置 HTTPS 或通过 localhost 代理访问。
# AUDIO_HTTPS=true  # 未来支持，当前请通过 localhost 或反向代理 HTTPS

# ── 端侧 ──
EDGE_GATEWAY_PORT=8090
FAST_INTENT_THRESHOLD_HIGH=0.85
FAST_INTENT_THRESHOLD_LOW=0.5

# ── Agent 注册中心 ──
# 长期不健康自动剔除：连续探测失败达此值（5s/轮 ≈ 10 分钟）整体注销（内存 + PG），
# Agent 改名/下线后的残留注册不再永生刷告警；活 Agent 每 10s 重注册自动豁免。0=禁用。
REGISTRY_EVICT_FAIL_COUNT=120

# ── 会话鉴权（R3.1，默认关；量产/演示翻开即闭环）──
# 默认全关/空 → 逐字保持现状（无 token 也能连、user_id=u1、下游按 PERMISSIONS_FAIL_OPEN 兜底）。
# 翻开演示：AUTH_REQUIRED=true + 配好下面三组 token + PERMISSIONS_FAIL_OPEN=false；
# HMI 无 token 连接会被 401 拒绝。见 docs/design/2026-07-02-r3.1-session-auth.md。
AUTH_REQUIRED=false
# 层 1（HMI↔edge-gateway）静态 token 表：条目用 ; 分隔，每条 token:user_id:vehicle_id:scope-csv。
# scope-csv 直接注入 meta.granted_scopes（与 _POC_DEFAULT_SCOPES 对齐=demo 全权限）。
AUTH_TOKENS=
# 例（单用户 demo，去掉行首 # 生效）：
# AUTH_TOKENS=demo-u1:u1:v1:vehicle.control,media.control,navigation,food.ordering,location.read,navigation.control,network.external,payment.invoke
# 匿名回退用户（AUTH_REQUIRED=false 且无有效 token 时用）；去掉了硬编码 user_id="u1"。
AUTH_DEFAULT_USER_ID=u1
VEHICLE_ID=v1
# HMI 连接 WS 携带的 token（须与 AUTH_TOKENS 里某条一致）；留空=不带 token。
VITE_WS_TOKEN=
# 层 2（edge-orchestrator↔cloud-gateway）通道 token（Hello 携带）与云侧允许集（逗号分隔，须含前者）。
CLOUD_CHANNEL_TOKEN=
CLOUD_CHANNEL_TOKENS=
# 例（去掉行首 # 生效）：
# CLOUD_CHANNEL_TOKEN=demo-channel-v1
# CLOUD_CHANNEL_TOKENS=demo-channel-v1
# 权限兜底（R2.2）：请求无 granted_scopes 时——true/默认=PoC 全开（保持现状）；
# false=fail-closed（仅无权限 Agent 可达）。R3.1 闭环演示置 false。
PERMISSIONS_FAIL_OPEN=true

# ── 服务间 mTLS（R3.2，默认关；量产/演示翻开）──
# 全默认关 → gRPC insecure，逐字保持现状。翻开演示：先 scripts/gen-certs.ps1|sh 生成 certs/，
# 再 GRPC_TLS=on 起全栈（证书由 compose 无条件挂到各 mesh 服务 /certs，关时代码不读、无害）。
# 单张共享 mesh 证书作 server+client 双身份；客户端校验名固定为 GRPC_TLS_SERVER_NAME
# （无视拨号地址，解决 agent 用动态容器 hostname 注册）。见 docs/design/2026-07-02-r3.2-service-mtls.md。
GRPC_TLS=off
GRPC_TLS_SERVER_NAME=cockpit-mesh
# 容器内证书路径（compose 已设默认，一般无需改）：
# GRPC_TLS_CA=/certs/ca.crt
# GRPC_TLS_CERT=/certs/server.crt
# GRPC_TLS_KEY=/certs/server.key

# ── 输入拒识 / 路由澄清（R4.4，置信度三段式；全 fail-open，=off 一键回今天）──
# REJECT：hands-free 语音源（meta.input_source=voice_*）+ LLM 判非受话 → 静默丢弃、不落库不进画像；
#         显式输入（文本/push-to-talk/候选选择）永不被拒。默认 on（作用域已被 hands-free + input_source 双重限定）。
REJECT_NON_ADDRESSED=on
# CLARIFY：真路由歧义句出 intent_choice 卡问一句再执行（明确句绝不反问）。默认 on（2026-07-08 真栈 CDP 验收后翻）。
CLARIFY_ENABLED=on
# CLARIFY_FALLBACK_MIN：LLM 挂/两次解析失败降级到语义 top-1 时的分数门槛，低于此值诚实降级不硬执行首个能力。
CLARIFY_FALLBACK_MIN=0.5

# ── 可观测 ──
OBS_COLLECTOR_PORT=8092
# 仅本地开发/演示开启；非开发环境必须设为 false
DEBUG_VEHICLE_CONTROL=true
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
# T3.6：Prometheus/Grafana 仅在 `docker compose --profile observability up` 时启用；
# PoC 默认凭证，对外暴露必须改（同 Postgres 密码的既有惯例）。
GRAFANA_ADMIN_PASSWORD=admin
# badcase 排查（会话/轮次/日志贯通，见 docs/design/2026-07-10-dashboard-badcase-observability-redesign.md）：
# 内容级采集（用户原话/话术/plan/LLM 输入输出，全部经统一脱敏）。开发/演示 on；
# **量产必须 off**（off 后只留长度+哈希指纹，链路形状排查不受影响）。
OBS_CONTENT_CAPTURE=on
# collector SQLite 保留期（天），badcase 标记的轮次豁免不清理
OBS_RETENTION_DAYS=7
# 日志上报门槛：≥ 该级别恒发 obs.log；带 trace_id 的 INFO 也发（轮次详情页执行痕迹）
LOG_SHIP_LEVEL=WARNING

# ── 通讯韧性（comms hardening；全部可选，代码内置安全默认值，留空即用默认）──
# gRPC keepalive：空闲连接也周期 ping，容器/NAT 掐断后一个周期内探测并重连重解析 DNS，
# 根治"依赖重启换 IP 后需重启依赖方"导致的断连/无响应。客户端 ping 周期须 ≥ 服务端最小间隔。
# GRPC_KEEPALIVE_TIME_MS=20000        # 每 20s 主动 keepalive ping
# GRPC_KEEPALIVE_TIMEOUT_MS=10000     # ping 10s 内无 ack 判定连接死亡并重连
# GRPC_MIN_PING_INTERVAL_MS=10000     # 服务端容忍 client ping 的最小间隔
# GRPC_MAX_MESSAGE_BYTES=16777216     # 单消息上限（16MB）
# GRPC_MAX_CONCURRENT_RPCS=0          # 服务端并发 RPC 上限，0=不限
# GRPC_SHUTDOWN_GRACE_S=10            # 优雅停机排空在途 RPC 的宽限秒数
# 熔断（云端 Agent dispatch）：连续失败 N 次→快速失败，不再每次吃满超时；冷却后半开探测自愈。
# CIRCUIT_FAILURE_THRESHOLD=5
# CIRCUIT_RECOVERY_TIMEOUT_S=30

# ── 智能提醒（reminder Agent）──
# 调度轮询秒（到点触发精度）；业务时区（中文时间表达解析与展示）
REMINDER_POLL_S=5
REMINDER_TZ=Asia/Shanghai

# ── 场景编排（scene-orchestrator Agent）──
# 用户自建场景持久化复用 POSTGRES_DSN（compose 已注入；无 PG 内存降级、重启丢失）。
# SCENE_VERIFY_WAIT_S=4        # 激活后多久做执行对账（等动作到端 + 状态 diff 经 NATS 回来）
# SCENE_TRIGGER_POLL_S=30      # 时间触发轮询间隔（场景触发不需要 reminder 的 5s 精度）
# SCENE_TRIGGER_THROTTLE_S=1800  # 同一触发器节流窗（边沿触发之上再加一层防骚扰）
# SCENE_CATALOG_DIR=           # VAL 词表目录（镜像构建期已 COPY；本地跑按「镜像→仓库相对」回退）
# LLM_MODEL_SCENE=             # scene.create 编译模型覆盖（留空用 primary 档）

# ── 记忆抽取（memory）──
# 合成会话跳过 LLM 抽取巩固（不烧 token、不污染真实画像）：按 session_id 前缀识别，
# 逗号分隔（契约登记 docs/conventions.md §9.2）。记忆管线自测用 memtest- 前缀（不在此列）。
